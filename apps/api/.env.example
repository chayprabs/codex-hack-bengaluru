# API settings for local development and Railway deploys.

# Optional until provider integrations are enabled.
OPENAI_API_KEY=sk-your-openai-api-key
GITHUB_TOKEN=github_pat_your-github-token
# Railway-friendly default for the standalone API container.
DATABASE_URL=sqlite:///./trustlayer.db
# Used by startup seed data and the demo audit endpoint.
DEMO_REPO_URL=https://github.com/vercel/next.js
# Comma-separated frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: `auto` picks the available sandbox backend and `docker` currently falls back to local.
AUDIT_EXECUTION_BACKEND=auto
