# Shared local defaults for the monorepo.
# The API reads values from the root .env file.

# Web app
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api

# API app
# Optional until provider integrations are enabled.
OPENAI_API_KEY=sk-your-openai-api-key
GITHUB_TOKEN=github_pat_your-github-token
DATABASE_URL=sqlite:///./trustlayer.db
DEMO_REPO_URL=https://github.com/vercel/next.js
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: `auto` resolves the best available sandbox backend, `docker` falls back to local for now.
AUDIT_EXECUTION_BACKEND=auto
